# Required for use of board peripherals
CONFIG_FLASH=y
CONFIG_GPIO=y
CONFIG_HAPTICS=y

# Required to flash and debug with the SEGGER J-Link
CONFIG_SERIAL=y
CONFIG_CONSOLE=y
CONFIG_RTT_CONSOLE=y
CONFIG_UART_RTT=y
CONFIG_USE_SEGGER_RTT=y

# Required to use shell interface with the SEGGER J-Link
CONFIG_SHELL_BACKEND_RTT=y
